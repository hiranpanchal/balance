# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://bw:bw_dev@localhost:5432/balance_wellness?schema=public"

# ─── Auth.js v5 ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-char-secret"

# The admin email that is allowed to log in (Mukti's email)
ADMIN_EMAIL="mukti@balanceandwellness.com"

# ─── Resend (email sending) ──────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Domain must be verified in Resend dashboard
EMAIL_FROM="Balance & Wellness <hello@balanceandwellness.com>"

# ─── Vercel Blob (image uploads) ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# ─── Public URL (used in emails) ─────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
